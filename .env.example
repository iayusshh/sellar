# ─── Supabase (client-exposed via Vite) ──────────────────────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=

# ─── Cashfree mode (client-exposed via Vite) ──────────────────────────────────
# "sandbox" for testing | "production" for real money
VITE_CASHFREE_MODE=sandbox

# ─── App URL ──────────────────────────────────────────────────────────────────
# Used as the Cashfree return_url base. In production, set to your deployed domain.
VITE_SITE_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# Supabase Edge Function secrets — set via `supabase secrets set`, NOT in .env
# ─────────────────────────────────────────────────────────────────────────────
# CASHFREE_APP_ID=          <- Cashfree dashboard → Credentials
# CASHFREE_SECRET_KEY=      <- Cashfree dashboard → Credentials
# CASHFREE_WEBHOOK_SECRET=  <- Cashfree dashboard → Webhooks → endpoint secret
# CASHFREE_ENV=sandbox      <- "sandbox" | "production"
# SUPABASE_SERVICE_ROLE_KEY=<- Supabase dashboard → Settings → API → service_role
# SITE_URL=http://localhost:5173   <- mirrors VITE_SITE_URL, server-side usage
#
# Deploy commands after setting secrets:
#   supabase functions deploy create-cashfree-order
#   supabase functions deploy verify-cashfree-order
#   supabase functions deploy cashfree-webhook --no-verify-jwt
#
# ─────────────────────────────────────────────────────────────────────────────
# NOTE: Never commit your actual .env file. Use .env.local (gitignored) instead.
# ─────────────────────────────────────────────────────────────────────────────
